APP_NAME=EvalForge
APP_ENV=dev
LOG_LEVEL=INFO
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///./evalforge.db
AUTO_CREATE_TABLES=true
DATABASE_ECHO=false
JUDGE_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
JUDGE_MODEL=gpt-4o-mini

# Postgres example:
# DATABASE_URL=postgresql+psycopg://evalforge:evalforge@postgres:5432/evalforge
# AUTO_CREATE_TABLES=false
